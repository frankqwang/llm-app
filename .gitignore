# IDE
.idea/
*.iml
.vscode/
.claude/

# OS
.DS_Store
Thumbs.db

# Local model files (don't commit large .litertlm/.task/.pt — auto-downloaded on first run)
*.litertlm
*.task
*.pt
models/

# Local debug scratch — adb pulls, uiautomator dumps, screenshots, logcat
# captures, perception/timeline samples. Anything generated by debugging
# sessions goes under .debug/ (with subdirs runs/ logs/ ui/) — do NOT scatter
# .run*, .ui*.xml, .screen.png, .sample_*.json at repo root.
.debug/

# Maestro UI test outputs — flows are committed under .maestro/flows/, but
# per-run video / screenshot / report artifacts are local-only.
.maestro/output/
.maestro/.cache/

# Third-party repos cloned at root (not part of this project, see pc-pilot/README.md)
ACE-Step-1.5/
